ALTER PROCEDURE [dbo].[1C_ExportContragentV2]	
	@id INT = NULL,
	@xml XML =NULL,
	@Error VARCHAR(MAX) out
AS
BEGIN
	DECLARE @new TABLE (ID INT, INN VARCHAR(17),KPP VARCHAR(11), CODE VARCHAR(200), Creator NVARCHAR(128))
	IF (@id IS NOT NULL AND @xml IS NOT NULL) 
	BEGIN
		SET @Error = 'Нельзя сразу использовать и ключ и xml! Что-то нужно одно!'		
		RETURN
	END 
	IF @id IS NOT NULL
	BEGIN 
		SELECT @xml=n.Data 
		FROM [1c].[In] n 
		WHERE n.Channel LIKE '%Contragent%'
	END
	IF @xml IS NULL
	BEGIN 
		SET @Error = 'Пакет для обработки контрагентов не найден!'		
		RETURN
	END

	DECLARE @SyncTbl TABLE(
		contrgentID INT NULL,
		requestId INT NULL,
		[1cID] UNIQUEIDENTIFIER NOT NULL,
		INN VARCHAR(17) NULL,
		[KPP] VARCHAR(11) NULL,
		[VATNo] VARCHAR(32) NULL,
		RegNum VARCHAR(32) NULL,
		[Name] VARCHAR(200) NOT NULL,
		[NameFull] VARCHAR(512) NOT NULL,
		[AdressLegal] VARCHAR(512) NULL,
		[Adress] VARCHAR(512) NULL,
		[AddressFact] VARCHAR(512) NULL,
		[BankName] VARCHAR(512) NULL,
		[AddressBank] VARCHAR(512) NULL,
		[Account] VARCHAR(20) NULL,
		[BIK] VARCHAR(9) NULL,
		[KC] VARCHAR(20) NULL,
		[Currency] INT NULL,		
		[CountryID] INT NULL)
	BEGIN TRY
	insert into @SyncTbl
	select 		
		c.id [contrgentID],
		r.ID [requestId],		
		x.ID [1cID],
		x.INN [INN],
		x.KPP [KPP],
		x.VATNo [VATNo],
		x.RegNum [RegNum],
		ISNULL(c.Code,isnull(r.ShortName, x.[Name])) [Name],
		x.NameFull [NameFull],
		x.AdressLegal [AdressLegal],
		x.Adress [Adress],
		x.AddressFact [AddressFact],
		x.BankName [BankName],
		x.AddressBank [AddressBank],
		x.Account [Account],
		x.BIK [BIK],
		x.KC [KC],
		cur.ID [Currency],
		cnn.ID [CountryID]
	from(select	
	x.Rec.value('./@ИД' , 'varchar(50)') as ID,
	x.Rec.value('./@ИНН' , 'varchar(13)') as INN,
	x.Rec.value('./@КПП' , 'varchar(13)') as KPP,
	x.Rec.value('./@НалоговыйНомер' , 'varchar(32)') as [VATNo],	
	x.Rec.value('./@РегистрационныйНомер' , 'varchar(32)') as [RegNum],	
	x.Rec.query('./Наименование').value('.', 'varchar(200)') AS 'Name',
	x.Rec.query('./НаименованиеПолное').value('.', 'varchar(512)') AS 'NameFull',
	x.Rec.query('./АдресЮридическийКонтрагента').value('.', 'varchar(512)') AS 'AdressLegal',
	x.Rec.query('./АдресПочтовыйКонтрагента').value('.', 'varchar(512)') AS 'Adress',
	x.Rec.query('./ИмяБанка').value('.', 'varchar(512)') as 'BankName',
	x.Rec.query('./АдресБанка').value('.', 'varchar(512)') as 'AddressBank',
	x.Rec.value('(./ИмяБанка/@Счет)[1]' , 'varchar(20)') as 'Account',	
	x.Rec.value('(./ИмяБанка/@БИК)[1]' , 'varchar(9)') as 'BIK',
	x.Rec.value('(./ИмяБанка/@КоррСчет)[1]' , 'char(20)') as 'KC',
	x.Rec.value('(./ИмяБанка/@Валюта)[1]' , 'varchar(3)') as 'Currency',
	x.Rec.query('./АдресФактическийКонтрагента').value('.', 'varchar(512)') AS 'AddressFact',
	x.Rec.value('(./СтранаРегистрации/@СсылкаСтранаРегистрацииКод)[1]', 'int') 'CountryID'
	FROM  @xml.nodes('/Контрагенты/Контрагент') as x(Rec)) x
	LEFT JOIN Contragents c on (ISNULL(x.inn,'')<>'' AND   c.INN= x.inn and c.KPP=x.kpp) or (isnull(x.inn,'')<>'' and c.RegNum=x.RegNum)
	LEFT JOIN RequestContragent r on (( isnull(x.inn,'')<>'' and   r.INN= x.inn and r.KPP=x.kpp) or (isnull(x.RegNum,'')<>'' and r.RegNum=x.RegNum)) and r.[Status]=2
	LEFT JOIN Countries cnn on cnn.id=x.CountryID
	LEFT JOIN Currencies cur on  (ISNULL(x.Currency,'')<>'' AND x.Currency=cur.NumCode) 
		OR (ISNULL(x.Currency,'')='' AND cur.Code=r.Currency)
	
	DECLARE @Request INT, @Contragent INT

	SELECT @Request =s.requestId , @Contragent=s.contrgentID FROM @SyncTbl s
	print '@Request='+ format(isnull(@Request,0),'###########')
	print '@@Contragent='+ format(isnull(@Contragent,0),'###########')
	IF ISNULL(@Request,0)=0 AND ISNULL(@Contragent,0)=0
	BEGIN
		UPDATE [1C].[In] SET LastExecuted =GETDATE(), Error='' WHERE Id=@id
		RETURN ----- не требуется обновление или создание контрагента, т.к. его нет ни в запросе ни в спраовочнике
	END

	BEGIN TRAN T1
		IF ISNULL(@Request,0)>0 
		BEGIN   --- завершаем запрос
			UPDATE [dbo].[RequestContragent] SET Status = 3  WHERE ID=@Request
		END
		IF isnull(@Contragent,0)>0
		BEGIN --- обновление существующего контрагента
		print 'начал обновление контрагента'
		--select * from @SyncTbl 
			UPDATE c SET  
				c.FullName = s.NameFull,
				c.ID_1C=s.[1cID],
				c.LAddress=s.AdressLegal,
				c.PAddress = s.Adress,
				c.RAddress = s.AddressFact ,
				c.CurrencyID = s.Currency,
				c.Country = s.CountryID
			FROM Contragents c
			INNER JOIN @SyncTbl s ON s.contrgentID =@Contragent			
			WHERE  c.id=@Contragent
			AND EXISTS (
			SELECT c.FullName,c.LAddress,c.CurrencyID,c.Country,ISNULL(c.ID_1C, '00000000-0000-0000-0000-000000000000')
			EXCEPT
			SELECT s.NameFull,s.AdressLegal,s.Currency,s.CountryID,s.[1cID]
			)			
			print 'обновил контрагента'
		END
		ELSE
		BEGIN --- создание нового контрагента
		print 'создание нового контрагента'
			INSERT INTO Contragents(
				[Resident],
				[INN],
				[KPP],
				[RegNum],
				[VATNo],
				[Code],
				[FullName],
				[LAddress],
				[PAddress],				
				RAddress, 
				ID_1C,
				Creator,
				CurrencyID,
				Country)
			OUTPUT 
				inserted.ID, 
				inserted.INN,
				inserted.KPP,
				inserted.Code,
				inserted.Creator
			INTO @new(ID,INN,KPP,CODE,Creator)
			SELECT  
				r.IsResident, 
				c.INN,
				c.KPP,
				c.RegNum,
				c.VATNo,
				r.ShortName,
				c.NameFull ,
				c.AdressLegal,
				c.Adress,				
				c.AddressFact,
				c.[1cID],
				r.Creator,
				c.Currency,
				c.CountryID
			FROM RequestContragent r 
			INNER JOIN @SyncTbl c ON c.requestId =@Request			
			where r.ID =@Request

			SELECT @Contragent =ID FROM @new 
			print '@Contragent = '+format(@Contragent, '##########')
			---	добавили статусы контрагента
			INSERT INTO ContragentStatus (Contragent,[Status])
			SELECT @Contragent, ID FROM [DBO].ufn_Table_From_String ((SELECT TOP(1) r.Codes  FROM RequestContragent  r WHERE r.ID=@Request))
			
			
			IF NOT EXISTS(SELECT 1 FROM Banks b INNER JOIN @SyncTbl s ON ISNULL(s.BIK,'')<>'' AND s.BIK=b.BIK or b.code=s.BankName)
			BEGIN --- создаем новые банки
				INSERT INTO Banks (BIK,Code,[Address],Correspondent)
				SELECT TOP(1)
					s.BIK,
					s.BankName,
					s.AddressBank,
					s.KC 
				FROM @SyncTbl s
			END
			--- создаем новые счета контрагента
			INSERT INTO Requisites (AccountNumber,Contragent,Bank,CurrencyID)
			SELECT 
				s.Account, @Contragent, b.ID, s.Currency
			FROM @SyncTbl s
			INNER JOIN Banks b ON ISNULL(s.BIK,'')<>'' AND b.BIK=s.BIK 			
			WHERE ISNULL(s.Account,'') <>''
			
		END
		IF ISNULL(@id,0)>0
		BEGIN
			UPDATE [1C].[In] SET Error = '',LastExecuted=GETDATE()  WHERE ID=@id
		END
	COMMIT TRAN T1

		DECLARE @CompanyCode varchar(32) = ''
	 SELECT @CompanyCode = [Value] FROM Constants WHERE code='MyCompany'

	 --- отправляем данные в телегу если что-то создали
	 INSERT INTO [dbo].[TelegramMessages] (
		 chat_id, 
		 message_id, 
		 TableName, 
		 ID_Table, 
		 [Action_or_Field], 
		 [text], 
		 reply_markup)
	 SELECT 
		t.TelegramID,
		[dbo].[fn_Send_Message_To_Telegram](
			t.TelegramID, 
			'Добавлен контрагент '+ n.code + ' для компании '+@CompanyCode , 
			'HTML', 
			NULL, 
			NULL),
		'Contragents',
		n.ID,
		'Создание контрагента',
		'Добавлен контрагент '+ n.code + ' для компании '+@CompanyCode,
		NULL
	  FROM @new n
	  OUTER APPLY(SELECT top(1) c.TelegramID from contacts c where c.dbuser=n.Creator ) t
	  WHERE t.TelegramID is not null
	  --- отправляем данные в телегу	

	END TRY
	BEGIN CATCH
		set @Error = 'PROC 1C_ExportContragentV2 ERROR: '+ERROR_MESSAGE()
		print @Error 
		IF @@TRANCOUNT >0 ROLLBACK TRAN
		IF ISNULL(@id,0)>0 BEGIN
			UPDATE [1C].[In] SET Error = @Error,LastExecuted=GETDATE()  WHERE ID=@id
		END
	END CATCH



END
